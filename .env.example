# Copy this file to `.env` and fill in your real values.

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional: restrict slash-command sync to a single guild during development
# (instant sync instead of the global 1-hour propagation). Leave empty for global.
# DEV_GUILD_ID=123456789012345678

# Optional: enable Spotify link support. Get these from a Spotify app at
# https://developer.spotify.com/dashboard. Without them, /play with a
# Spotify URL will politely refuse; YouTube links and search still work.
# SPOTIFY_CLIENT_ID=your-spotify-client-id
# SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
#
# Optional: enable access to Spotify-owned editorial and algorithmic
# playlists (Today's Top Hits, Discover Weekly, etc). Requires a one-off
# browser login via `uv run spotify_login.py`. The redirect URI must be
# registered on your Spotify app's dashboard, must be a loopback address
# (not "localhost"), and must include an explicit port.
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
